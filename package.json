{
  "name": "tachikoma-collab",
  "displayName": "Tachikoma Collab",
  "publisher": "Tachikoma",
  "description": "Connect to a Tachikoma computer: browse monorepo contexts, edit remote files, attach zellij/tmux terminals, and live-collaborate via CRDT.",
  "version": "5.13.0",
  "license": "MIT",
  "icon": "media/icon-128.png",
  "homepage": "https://github.com/HoliChrys/tachikoma-collab#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/HoliChrys/tachikoma-collab"
  },
  "bugs": {
    "url": "https://github.com/HoliChrys/tachikoma-collab/issues"
  },
  "qna": "marketplace",
  "pricing": "Free",
  "galleryBanner": {
    "color": "#1E1E2E",
    "theme": "dark"
  },
  "keywords": [
    "tachikoma",
    "collaboration",
    "crdt",
    "remote",
    "ai"
  ],
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Other",
    "AI",
    "Programming Languages",
    "Notebooks"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "tachikoma.connect",
        "title": "Tachikoma: Connect to Computer"
      },
      {
        "command": "tachikoma.disconnect",
        "title": "Tachikoma: Disconnect",
        "icon": "$(debug-disconnect)"
      },
      {
        "command": "tachikoma.getMcpSession",
        "title": "Tachikoma: Get MCP Session (for MCP marketplace)"
      },
      {
        "command": "tachikoma.toggleDaemon",
        "title": "Tachikoma: Toggle Local Agent",
        "icon": "$(vm-active)"
      },
      {
        "command": "tachikoma.openLocalTerminal",
        "title": "Tachikoma: Open Local Terminal",
        "icon": "$(terminal)"
      },
      {
        "command": "tachikoma.showOutput",
        "title": "Tachikoma: Show Logs"
      },
      {
        "command": "tachikoma.startCollaborating",
        "title": "Tachikoma: Start Collaborating on File"
      },
      {
        "command": "tachikoma.stopCollaborating",
        "title": "Tachikoma: Stop Collaborating on File"
      },
      {
        "command": "tachikoma.attachSession",
        "title": "Tachikoma: Attach Session"
      },
      {
        "command": "tachikoma.openZellij",
        "title": "Tachikoma: Open Zellij Web"
      },
      {
        "command": "tachikoma.refreshSessions",
        "title": "Tachikoma: Refresh Sessions",
        "icon": "$(refresh)"
      },
      {
        "command": "tachikoma.toggleShowAllSessions",
        "title": "Tachikoma: Toggle Show All Sessions",
        "icon": "$(filter)"
      },
      {
        "command": "tachikoma.invalidateCache",
        "title": "Tachikoma: Invalidate Cache and Resync"
      },
      {
        "command": "tachikoma.copyWithReference",
        "title": "Tachikoma: Copy Selection with File Reference"
      },
      {
        "command": "tachikoma.newFile",
        "title": "New File",
        "icon": "$(new-file)"
      },
      {
        "command": "tachikoma.newFolder",
        "title": "New Folder",
        "icon": "$(new-folder)"
      },
      {
        "command": "tachikoma.deleteEntry",
        "title": "Delete",
        "icon": "$(trash)"
      },
      {
        "command": "tachikoma.openInWorkspace",
        "title": "Open in Workspace",
        "icon": "$(root-folder-opened)"
      },
      {
        "command": "tachikoma.remoteTerminal",
        "title": "Open Remote Terminal",
        "icon": "$(terminal)"
      },
      {
        "command": "tachikoma.copilot.open",
        "title": "Tachikoma: Open Copilot",
        "category": "Tachikoma"
      },
      {
        "command": "tachikoma.mcp.selectProfile",
        "title": "Tachikoma: Select MCP Profile",
        "category": "Tachikoma"
      },
      {
        "command": "tachikoma.mcp.clearActiveProfile",
        "title": "Tachikoma: Clear Active MCP Profile",
        "category": "Tachikoma"
      },
      {
        "command": "tachikoma.mcp.refresh",
        "title": "Tachikoma: Refresh MCP",
        "category": "Tachikoma",
        "icon": "$(refresh)"
      },
      {
        "command": "tachikoma.connectWithToken",
        "title": "Connect with API Token",
        "category": "Tachikoma"
      },
      {
        "command": "tachikoma.agents.spawn",
        "title": "Spawn Local Agent",
        "category": "Tachikoma"
      },
      {
        "command": "tachikoma.agents.stop",
        "title": "Stop Agent",
        "category": "Tachikoma"
      },
      {
        "command": "tachikoma.swarm.create",
        "title": "Create Swarm",
        "category": "Tachikoma"
      },
      {
        "command": "tachikoma.swarm.addMember",
        "title": "Add Agent to Swarm",
        "category": "Tachikoma"
      },
      {
        "command": "tachikoma.composer.open",
        "title": "Composer (Cmd+I)",
        "category": "Tachikoma"
      },
      {
        "command": "tachikoma.welcome.open",
        "title": "Open Welcome Page",
        "category": "Tachikoma",
        "icon": "$(home)"
      },
      {
        "command": "tachikoma.context.quickSwitch",
        "title": "Quick Switch Context",
        "category": "Tachikoma",
        "icon": "$(arrow-swap)"
      }
    ],
    "keybindings": [
      {
        "command": "tachikoma.copyWithReference",
        "key": "ctrl+shift+alt+c",
        "mac": "cmd+shift+alt+c",
        "when": "editorHasSelection"
      },
      {
        "command": "tachikoma.composer.open",
        "key": "cmd+i",
        "mac": "cmd+i",
        "win": "ctrl+i",
        "linux": "ctrl+i",
        "when": "tachikoma:connected"
      },
      {
        "command": "tachikoma.context.quickSwitch",
        "key": "ctrl+shift+h",
        "mac": "cmd+shift+h",
        "win": "ctrl+shift+h",
        "linux": "ctrl+shift+h",
        "when": "tachikoma:connected"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "tachikoma.refreshSessions",
          "when": "view == tachikomaSessions",
          "group": "navigation"
        },
        {
          "command": "tachikoma.toggleShowAllSessions",
          "when": "view == tachikomaSessions",
          "group": "navigation"
        },
        {
          "command": "tachikoma.newFile",
          "when": "view == tachikomaContextTree",
          "group": "navigation@1"
        },
        {
          "command": "tachikoma.newFolder",
          "when": "view == tachikomaContextTree",
          "group": "navigation@2"
        },
        {
          "command": "tachikoma.disconnect",
          "when": "view == tachikomaContextTree",
          "group": "navigation@99"
        },
        {
          "command": "tachikoma.mcp.refresh",
          "when": "view == tachikomaMcpCopilot",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "tachikoma.newFile",
          "when": "view == tachikomaContextTree && viewItem =~ /^(space|folder)$/",
          "group": "1_modification@1"
        },
        {
          "command": "tachikoma.newFolder",
          "when": "view == tachikomaContextTree && viewItem =~ /^(space|folder)$/",
          "group": "1_modification@2"
        },
        {
          "command": "tachikoma.openInWorkspace",
          "when": "view == tachikomaContextTree && viewItem =~ /^(galaxy|system|space)$/",
          "group": "0_open@1"
        },
        {
          "command": "tachikoma.remoteTerminal",
          "when": "view == tachikomaContextTree && viewItem =~ /^(galaxy|system|space|folder)$/",
          "group": "0_open@2"
        },
        {
          "command": "tachikoma.deleteEntry",
          "when": "view == tachikomaContextTree && viewItem =~ /^(file|folder)$/",
          "group": "2_danger@1"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "tachikomaExplorer",
          "title": "Tachikoma",
          "icon": "media/tachikoma-icon.svg"
        }
      ]
    },
    "views": {
      "tachikomaExplorer": [
        {
          "id": "tachikomaContextTree",
          "name": "Contexts"
        },
        {
          "id": "tachikomaCollaborators",
          "name": "Collaborators"
        },
        {
          "id": "tachikomaSessions",
          "name": "Sessions"
        },
        {
          "id": "tachikomaMcpCopilot",
          "name": "MCP Copilot",
          "when": "tachikoma.connected"
        },
        {
          "id": "tachikomaCopilot",
          "name": "Copilot",
          "type": "webview",
          "when": "tachikoma.connected"
        },
        {
          "id": "tachikomaAgents",
          "name": "Tachikoma Agents",
          "when": "tachikoma:connected"
        },
        {
          "id": "tachikomaMcpSettings",
          "name": "MCP Settings",
          "type": "webview",
          "when": "tachikoma.connected"
        }
      ]
    },
    "terminal": {
      "profiles": [
        {
          "id": "tachikoma.remoteShell",
          "title": "Tachikoma Remote",
          "icon": "remote"
        },
        {
          "id": "tachikoma.zellijSession",
          "title": "Tachikoma (zellij)",
          "icon": "terminal"
        }
      ]
    },
    "configuration": {
      "title": "Tachikoma",
      "properties": {
        "tachikoma.host": {
          "type": "string",
          "default": "",
          "description": "Tachikoma computer address (e.g., http://localhost:8000)"
        },
        "tachikoma.autoConnect": {
          "type": "boolean",
          "default": false,
          "description": "Automatically connect on startup"
        },
        "tachikoma.monorepoRoot": {
          "type": "string",
          "default": "",
          "description": "Path to the tachikoma monorepo root on the remote computer (e.g., /home/ubuntu/tachikoma_monorepo)"
        },
        "tachikoma.showAllSessions": {
          "type": "boolean",
          "default": false,
          "description": "Show sessions from all contexts (not just active ones)"
        },
        "tachikoma.autoCollab": {
          "type": "boolean",
          "default": true,
          "description": "Automatically start live collaboration (CRDT + presence) when opening remote files"
        },
        "tachikoma.copilot.url": {
          "type": "string",
          "default": "",
          "description": "Optional dashboard URL where the CopilotKit chat lives. When set, the Copilot view embeds it as an iframe. Empty = use the local-only profile picker UI."
        },
        "tachikoma.terminals.persist": {
          "type": "boolean",
          "default": true,
          "description": "Track terminal sessions opened by the extension and persist them per-user via the backend for cross-machine replay."
        },
        "tachikoma.terminals.autoReplayOnConnect": {
          "type": "boolean",
          "default": true,
          "description": "Automatically restore previously-tracked terminals when reconnecting."
        },
        "tachikoma.terminals.crossMachineReplay": {
          "type": "boolean",
          "default": false,
          "description": "Replay terminals opened on other machines (same user) automatically. Default: false (opt-in)."
        },
        "tachikoma.terminals.killOnDisconnect": {
          "type": "boolean",
          "default": true,
          "description": "Close tracked terminals when disconnecting from Tachikoma."
        },
        "tachikoma.inlineCompletion.engine": {
          "type": "string",
          "enum": [
            "tachikoma",
            "copilot",
            "off"
          ],
          "default": "tachikoma",
          "description": "Engine for inline completion: tachikoma (POST /api/agent/completion), copilot (delegate), off."
        }
      }
    },
    "chatParticipants": [
      {
        "id": "tachikoma",
        "fullName": "Tachikoma",
        "name": "tachikoma",
        "description": "Talk to your Tachikoma agents (Hermes runtime, MCP tools)",
        "isSticky": true
      }
    ],
    "walkthroughs": [
      {
        "id": "tachikoma.getStarted",
        "title": "Get Started with Tachikoma",
        "description": "Connect to your Tachikoma computer, browse your monorepo, open a remote terminal, and chat with @tachikoma agents.",
        "steps": [
          {
            "id": "tachikoma.walkthrough.connect",
            "title": "Connect with API Token",
            "description": "Paste a Tachikoma API token to link this editor to your computer. [Connect with API Token](command:tachikoma.connectWithToken)",
            "media": {
              "markdown": "media/walkthrough/connect.md"
            },
            "completionEvents": [
              "onCommand:tachikoma.connectWithToken"
            ]
          },
          {
            "id": "tachikoma.walkthrough.browse",
            "title": "Browse your monorepo",
            "description": "Open the Tachikoma activity bar to navigate galaxies, systems, and spaces. [Open Contexts](command:tachikomaContextTree.focus)",
            "media": {
              "markdown": "media/walkthrough/browse.md"
            },
            "completionEvents": [
              "onView:tachikomaContextTree"
            ]
          },
          {
            "id": "tachikoma.walkthrough.zellij",
            "title": "Open a zellij terminal",
            "description": "Start a Tachikoma (zellij) terminal from the integrated terminal profile dropdown to attach to a shared remote session.",
            "media": {
              "markdown": "media/walkthrough/zellij.md"
            }
          },
          {
            "id": "tachikoma.walkthrough.chat",
            "title": "Chat with @tachikoma",
            "description": "Open the chat view and talk to your agents via the @tachikoma participant. [Chat with @tachikoma](command:workbench.action.chat.open?%7B%22query%22%3A%22%40tachikoma%20%22%7D)",
            "media": {
              "markdown": "media/walkthrough/chat.md"
            }
          },
          {
            "id": "tachikoma.walkthrough.mcp",
            "title": "Manage MCP profile",
            "description": "Pick the MCP capability profile that scopes your agents tools and dashboards. [Open MCP Copilot](command:tachikoma.copilot.open)",
            "media": {
              "markdown": "media/walkthrough/mcp.md"
            },
            "completionEvents": [
              "onCommand:tachikoma.copilot.open"
            ]
          }
        ]
      }
    ]
  },
  "scripts": {
    "compile": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap --minify",
    "watch": "npm run compile -- --watch",
    "typecheck": "tsc -p ./ --noEmit",
    "lint": "eslint src",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "22.x",
    "@types/vscode": "^1.75.1",
    "@types/ws": "^8.18.1",
    "@vscode/vsce": "^3.3.2",
    "esbuild": "^0.25.0",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "eventsource": "^3.0.7",
    "lib0": "^0.2.103",
    "ws": "^8.18.2",
    "y-protocols": "^1.0.6",
    "yjs": "^13.6.27"
  }
}
